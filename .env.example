# Environment variables for Find

# ──────────────────────────────────────────────────────────────────────────
# SECURITY: the values below are DEVELOPMENT DEFAULTS. Before deploying with
# ENVIRONMENT=production you MUST replace every credential (POSTGRES_PASSWORD,
# REDIS_PASSWORD, MINIO_ROOT_USER/PASSWORD, and the matching *_URL strings).
# The API refuses to start in production while the default db/object-store
# credentials are still in place. Datastore ports are bound to 127.0.0.1 in
# docker-compose, so the datastores are not reachable from the network.
# ──────────────────────────────────────────────────────────────────────────

# Database
# POSTGRES_PASSWORD is consumed by the db container; DATABASE_URL must embed
# the same password. Keep the two in sync.
POSTGRES_PASSWORD=find123
DATABASE_URL=postgresql://find:find123@db:5432/find
# Storage Backend Selection
# Choose "minio" (default) for object storage, or "local" for filesystem storage (desktop mode)
STORAGE_BACKEND=minio
# Only used when STORAGE_BACKEND=local. Directory where files are stored on disk.
LOCAL_STORAGE_PATH=./data/storage
# Preferred provider-neutral object storage settings. MINIO_* below remains supported for compatibility.
STORAGE_ENDPOINT=minio:9000
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin
STORAGE_BUCKET=images
STORAGE_SECURE=false
STORAGE_PUBLIC_READ=false
STORAGE_PUBLIC_ENDPOINT=http://localhost:9200/images
STORAGE_AUTO_CREATE_BUCKET=true

# MinIO Object Storage
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_HOST_PORT=9200
MINIO_CONSOLE_HOST_PORT=9201
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=images
MINIO_SECURE=false
MINIO_PUBLIC_READ=false
# Browser-facing MinIO base URL. Used for public files and to rewrite signed
# URLs when the API talks to MinIO through the internal `minio:9000` hostname.
MINIO_PUBLIC_ENDPOINT=http://localhost:9200/images

# Redis
# Redis requires a password (set on the redis container via REDIS_PASSWORD).
# REDIS_URL must embed the same password: redis://:<password>@redis:6379
REDIS_PASSWORD=find-redis-dev
REDIS_URL=redis://:find-redis-dev@redis:6379

# API Configuration
ENVIRONMENT=local
API_HOST=0.0.0.0
API_PORT=8000

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_MINIO_BUCKET=images
# Only used as a fallback when objects are publicly readable.
NEXT_PUBLIC_MINIO_URL=http://localhost:9200
NEXT_PUBLIC_MAX_BULK_FILES=200
# Client-side upload size limit (MB). Keep in sync with MAX_UPLOAD_SIZE_MB (server-side).
# If this exceeds MAX_UPLOAD_SIZE_MB, files will pass client validation but be rejected by the server.
NEXT_PUBLIC_MAX_UPLOAD_SIZE_MB=50

# ML Model Settings
ML_MODE=full
# Remote ML Acceleration
# Disabled by default. Only used when ML_MODE=remote.
# REMOTE_ML_URL must point to a self-hosted Find ML server.
REMOTE_ML_URL=
REMOTE_ML_API_KEY=
REMOTE_ML_STRIP_EXIF=true
# Comma-separated: embed,caption,detect,ocr,cluster
REMOTE_ML_FEATURES=embed,caption,detect,ocr,cluster
# Idle time before an ML model is unloaded from memory (seconds)
ML_MODEL_IDLE_TTL_SECONDS=300
# Maximum number of heavy ML models to keep in memory simultaneously.
# Increase this if you have plenty of VRAM/RAM (e.g., 5-8 for full functionality).
# Decrease this if you experience OOM (Out of Memory) errors.
ML_MAX_LOADED_MODELS=5
# RQ worker class. SimpleWorker keeps ML models warm in the worker process so
# ML_MODEL_IDLE_TTL_SECONDS can control when they are unloaded.
RQ_WORKER_CLASS=rq.worker.worker_classes.SimpleWorker
CLIP_MODEL=ViT-B-16-SigLIP
CLIP_PRETRAINED=webli
BLIP_MODEL=microsoft/Florence-2-base
YOLO_MODEL=yolo26n.pt
USE_GPU=true
YOLO_HALF=true
BACKEND_BASE_IMAGE=nvidia/cuda:12.1.1-runtime-ubuntu22.04
BACKEND_PYTHON_VERSION=3.12
EMBEDDING_DIM=768

# Processing Settings
MAX_UPLOAD_SIZE_MB=50
MAX_BULK_FILES=200
MAX_BULK_TOTAL_SIZE_MB=500
MAX_BULK_COMPRESSION_RATIO=100
WORKER_TIMEOUT=600
BATCH_SIZE=1

# Clustering Settings
MIN_CLUSTER_SIZE=2
MIN_SAMPLES=1
CLUSTERING_N_JOBS=-1
CLUSTERING_BACKEND=auto

# Auth (small-team instance sharing)
# Uncomment to customize session and invite lifetimes.
# SESSION_TTL_HOURS=24
# INVITE_TTL_HOURS=48
